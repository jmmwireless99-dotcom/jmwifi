APP_NAME="JM WIFI Billing System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Manila
APP_URL=https://billing.jmwifi.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Database (MySQL)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jmwifi_billing
DB_USERNAME=jmwifi_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ---------------------------------------------------------------------------
# Session / Cache / Queue
# Use 'database' driver for all three — no Redis required to run this app,
# though Redis is a drop-in upgrade later if you want it.
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---------------------------------------------------------------------------
# Mail (optional — only needed if you enable email notifications later)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="billing@jmwifi.example"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# PayMongo (GCash payments)
# Get these from https://dashboard.paymongo.com/developers > API Keys
# ---------------------------------------------------------------------------
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_BASE_URL=https://api.paymongo.com/v1
PAYMONGO_SUCCESS_URL="${APP_URL}/payment/success"
PAYMONGO_FAILED_URL="${APP_URL}/payment/failed"

# ---------------------------------------------------------------------------
# Google Maps (client location pins)
# Get an API key from https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
MAP_DEFAULT_LAT=14.5995
MAP_DEFAULT_LNG=120.9842

# ---------------------------------------------------------------------------
# MikroTik
# ---------------------------------------------------------------------------
MIKROTIK_TIMEOUT=5
MIKROTIK_WARNING_DAYS=3
